{
  "name": "webmcp-adapter-react",
  "version": "0.0.1",
  "description": "React hooks for WebMCP tool registration. Provides a simple useTools hook to register AI-powered tools within React component lifecycle.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "webmcp-adapter": "0.0.4"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "typescript": "^5.9.3",
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.5.4"
  },
  "keywords": [
    "webmcp",
    "mcp",
    "react",
    "hooks",
    "ai",
    "tools",
    "model-context-protocol",
    "browser",
    "copilot"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/asouqi/webmcp-adapter-react.git"
  },
  "license": "MIT"
}
